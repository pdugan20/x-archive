# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# X/Twitter API (OAuth 1.0a)
# Create an app at: https://developer.x.com/en/portal/dashboard
X_API_KEY=your-consumer-key
X_API_SECRET=your-consumer-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret
X_BEARER_TOKEN=your-bearer-token

# Cron Job Authentication
# Generate with: openssl rand -base64 32
CRON_SECRET=your-random-secret-at-least-32-characters

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry Error Monitoring (Optional)
# Create a project at: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
