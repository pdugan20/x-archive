# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# X/Twitter API (OAuth 2.0 with PKCE)
# Create an app at: https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=your-x-app-client-id
X_CLIENT_SECRET=your-x-app-client-secret
X_ACCESS_TOKEN=your-user-access-token
X_REFRESH_TOKEN=your-refresh-token

# Cron Job Authentication
# Generate with: openssl rand -base64 32
CRON_SECRET=your-random-secret-at-least-32-characters

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry Error Monitoring (Optional)
# Create a project at: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
